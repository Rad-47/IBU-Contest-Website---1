# ─── Google Drive Upload Credentials ───────────────────────────────────────
# Steps to set up:
#
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select an existing one)
# 3. Enable the "Google Drive API" for that project
# 4. Go to IAM & Admin → Service Accounts → Create Service Account
# 5. Give it any name (e.g. "fanlinc-upload"), click Create
# 6. Skip optional steps, click Done
# 7. Click the service account → Keys tab → Add Key → JSON → download the file
# 8. Open the JSON file — copy the values below:
#
# 9. IMPORTANT: Share your Google Drive folder with the service account email
#    (the "client_email" value). Give it "Editor" access.
#
# Then rename this file to .env.local and fill in the values.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value exactly — keep the \n characters as-is
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
